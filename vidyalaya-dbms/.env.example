# Master DB (tenant registry)
MASTER_DB_URL=jdbc:postgresql://localhost:5433/vidyalaya_master
MASTER_DB_USER=vidyalaya
MASTER_DB_PASSWORD=vidyalaya

# JWT (min 256 bits / 32 bytes for HMAC)
JWT_SECRET=change-me-use-openssl-rand-base64-32-minimum-32-chars!!

# AES-256-GCM for tenant secrets (Base64 of 32 raw bytes; dev default matches application.yml)
VIDYALAYA_ENCRYPTION_KEY=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=

# Super-admin bootstrap (first run)
SUPER_ADMIN_USERNAME=superadmin
# Use quotes in shell exports so ! is not mangled: export SUPER_ADMIN_PASSWORD='ChangeMe123!'
SUPER_ADMIN_PASSWORD=ChangeMe123!

# OpenAI (optional; chatbot disabled if empty)
OPENAI_API_KEY=

# CORS (comma-separated origins for dashboard)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
